# Disarankan production: string acak minimal 16 karakter (JWT). Kosong = fallback bawaan (jangan dipakai serius).
SESSION_SECRET=

# CORS — tanpa env = mirror `Origin` (cocok https://gemini.google.com, AI Studio, dll.).
# Satu origin tetap:
# CORS_ORIGIN=https://gemini.google.com
# Beberapa origin (pisah koma, harus persis sama dengan header Origin browser):
# CORS_ORIGINS=https://gemini.google.com,https://aistudio.google.com,https://aurora-panel.vercel.appaurora

# Opsional: admin pertama saat DB masih kosong (ganti password setelah login).
BOOTSTRAP_ADMIN_USER=   
BOOTSTRAP_ADMIN_PASSWORD=015999

# SQLite lokal (default): kosongkan DATABASE_URL → file `data/app.db`.
# Turso — salin URL dari dashboard / `turso db show <nama>`:
# DATABASE_URL=libsql://aurora-nazrul-dev.aws-ap-northeast-1.turso.io
# Token (rahasia): buat di dashboard Turso atau `turso db tokens create <nama-db>`
# TURSO_AUTH_TOKEN=
